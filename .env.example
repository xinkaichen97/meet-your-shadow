# Local development configuration
# For deployment, these are passed via `agents-cli deploy` (see README.md).

# Gemini API via Google AI Studio (default here — no GCP billing required).
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-api-key-here

# Alternatively, for Vertex AI (requires a GCP project with billing enabled),
# comment out GEMINI_API_KEY above and uncomment:
# GOOGLE_GENAI_USE_VERTEXAI=true
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=global
